{
    "name": "lytecache/lytecache",
    "description": "Redis-like caching with zero infrastructure -- an embedded, SQLite-backed cache for PHP and Laravel.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["cache", "sqlite", "redis-alternative", "laravel", "ttl", "embedded"],
    "homepage": "https://lytecache.github.io/lytecache",
    "support": {
        "issues": "https://github.com/lytecache/lytecache/issues",
        "source": "https://github.com/lytecache/lytecache",
        "docs": "https://lytecache.github.io/lytecache"
    },
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*"
    },
    "suggest": {
        "illuminate/contracts": "Required to use the Laravel cache driver (^10.0|^11.0|^12.0|^13.0).",
        "illuminate/support": "Required to use the Laravel service provider (^10.0|^11.0|^12.0|^13.0)."
    },
    "require-dev": {
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Lytecache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lytecache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit",
        "stan": "@php vendor/bin/phpstan analyse --memory-limit=512M",
        "pint": "@php vendor/bin/pint",
        "pint:test": "@php vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lytecache\\Laravel\\LytecacheServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
