{
  "name": "lytecache",
  "version": "0.2.0",
  "description": "Redis-like caching with zero infrastructure -- an embedded, SQLite-backed cache for Node.js.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cache",
    "sqlite",
    "redis-alternative",
    "ttl",
    "embedded"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "vite": "^6.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lytecache/lytecache.git",
    "directory": "lytecache-node"
  },
  "homepage": "https://lytecache.github.io/lytecache",
  "bugs": {
    "url": "https://github.com/lytecache/lytecache/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
